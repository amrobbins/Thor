+TEST(AttentionApi, OutputResidualTrainingGraphPlacesForSelfAndCrossAttention) {
+    for (bool useCrossAttention : {false, true}) {
+        Api::Network network(useCrossAttention ? "cross_attention_output_residual" : "self_attention_output_residual");
+        Api::NetworkInput queryInput = Api::NetworkInput::Builder()
+                                           .network(network)
+                                           .name("query")
+                                           .dimensions({5, 8})
+                                           .dataType(DataType::BF16)
+                                           .build();
+        std::optional<Api::NetworkInput> contextInput;
+        if (useCrossAttention) {
+            contextInput = Api::NetworkInput::Builder()
+                               .network(network)
+                               .name("context")
+                               .dimensions({7, 8})
+                               .dataType(DataType::BF16)
+                               .build();
+        }
+        Api::NetworkInput residualInput = Api::NetworkInput::Builder()
+                                              .network(network)
+                                              .name("residual")
+                                              .dimensions({5, 8})
+                                              .dataType(DataType::BF16)
+                                              .build();
+
+        Api::Attention::Builder builder;
+        builder.network(network)
+            .featureInput(queryInput.getFeatureOutput().value())
+            .outputResidualInput(residualInput.getFeatureOutput().value())
+            .numHeads(2)
+            .headDim(4)
+            .valueDim(4)
+            .outputFeatures(8)
+            .weightsDataType(DataType::BF16)
+            .computeDataType(DataType::FP32)
+            .outputDataType(DataType::BF16);
+        if (contextInput.has_value()) {
+            builder.contextInput(contextInput->getFeatureOutput().value());
+        }
+        Api::Attention attention = builder.build();
+        Api::NetworkOutput::Builder()
+            .network(network)
+            .name("output")
+            .inputTensor(attention.getFeatureOutput().value())
+            .dataType(DataType::BF16)
+            .build();
+
+        std::vector<Event> initDoneEvents;
+        std::shared_ptr<Api::PlacedNetwork> placed = network.place(4, initDoneEvents, false);
+        synchronizeEvents(initDoneEvents);
+        ASSERT_NE(placed, nullptr);
+        Impl::StampedNetwork& stamped = placed->getStampedNetwork(0);
+        std::shared_ptr<Impl::CustomLayer> physicalAttention =
+            std::dynamic_pointer_cast<Impl::CustomLayer>(stamped.getPhysicalLayerFromApiLayer(attention.getId()));
+        ASSERT_NE(physicalAttention, nullptr);
+        ASSERT_TRUE(physicalAttention->getFeatureOutput().has_value());
+        EXPECT_EQ(physicalAttention->getFeatureOutput()->getDimensions(),
+                  (std::vector<uint64_t>{4, 5, 8}));
+    }
+}
